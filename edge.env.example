# Remote orchestrator URL served by the VPS.
ELOWEN_API_URL=https://api.ericburden.dev

# NATS is expected to arrive through a local SSH tunnel.
ELOWEN_NATS_URL=nats://127.0.0.1:4222

# Device identity shown in the orchestrator.
ELOWEN_DEVICE_ID=elowen-laptop
ELOWEN_DEVICE_NAME=Elowen Laptop
ELOWEN_DEVICE_PRIMARY=true

# Repo and capability declarations sent during registration.
ELOWEN_ALLOWED_REPOS=elowen-api,elowen-ui,elowen-edge,elowen-notes,elowen-platform
ELOWEN_DEVICE_CAPABILITIES=codex,git,build,test

# Local checkout and worktree paths on the laptop.
ELOWEN_EDGE_WORKSPACE_ROOT=D:\Projects\elowen
ELOWEN_EDGE_WORKTREE_ROOT=D:\Projects\elowen\.elowen\worktrees

# Optional real Codex runner and logging overrides.
# ELOWEN_CODEX_COMMAND=codex
# ELOWEN_CODEX_ARGS_JSON=["--model","gpt-5.4"]
# ELOWEN_LOG_FORMAT=json
# RUST_LOG=info
